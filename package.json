{
	"name": "create-nimbus-docs",
	"version": "0.1.0",
	"description": "Scaffold a Nimbus docs site",
	"type": "module",
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"lint": "eslint . --max-warnings=0",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"start": "node dist/index.js",
		"prepare": "tsup",
		"typecheck": "tsc --noEmit",
		"verify": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm build"
	},
	"bin": {
		"create-nimbus-docs": "./dist/index.js"
	},
	"files": [
		"dist",
		"template"
	],
	"engines": {
		"node": ">=18.0.0"
	},
	"dependencies": {
		"@clack/prompts": "^0.9.1",
		"mri": "^1.2.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/mri": "^1.1.4",
		"@types/node": "^20.17.0",
		"eslint": "^10.2.0",
		"globals": "^17.5.0",
		"prettier": "^3.8.2",
		"tsup": "^8.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.58.1"
	},
	"license": "MIT"
}
