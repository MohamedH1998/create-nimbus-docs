---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import "../styles/globals.css";
---

<BaseLayout title="Page not found">
  <div class="flex min-h-screen flex-col">
    <Header />
    <main id="main-content" class="flex flex-1 flex-col items-center justify-center px-6 py-24 text-center">
      <p class="text-sm font-medium text-text-subtle">404</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-text sm:text-4xl">Page not found</h1>
      <p class="mt-3 text-sm leading-relaxed text-text-subtle">The page you're looking for doesn't exist or has been moved.</p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 rounded-lg bg-fill px-5 py-2.5 text-sm font-medium text-text-inverse shadow-sm transition-all hover:bg-fill-hover hover:shadow"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back to home
      </a>
    </main>
    <Footer />
  </div>
</BaseLayout>
