---
import { cn } from "@/lib/cn";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"a"> {
  title: string;
  description?: string;
  href: string;
}

const { title, description, href, class: className, ...attrs } = Astro.props;
---

<a
  href={href}
  class={cn("group flex items-center justify-between gap-3 rounded-xl bg-base p-5 shadow-sm ring ring-line no-underline text-inherit transition-all hover:shadow-default hover:ring-line-strong hover:-translate-y-px", className)}
  {...attrs}
>
  <div class="min-w-0">
    <h3 class="m-0 text-sm font-semibold leading-snug text-text transition-colors group-hover:text-brand">{title}</h3>
    {description && <p class="mt-1 text-[0.8125rem] leading-normal text-text-subtle">{description}</p>}
  </div>
  <svg class="shrink-0 text-text-subtle transition-all group-hover:translate-x-0.5 group-hover:text-brand" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true">
    <path d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L164.69,128,90.34,53.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z" />
  </svg>
</a>
