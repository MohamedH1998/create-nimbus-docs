---
import { cn } from "@/lib/cn";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"article"> {
  title: string;
  /** Emoji or short text displayed above the title. */
  icon?: string;
}

const { title, icon, class: className, ...attrs } = Astro.props;
---

<article class={cn("my-4 rounded-xl bg-base p-5 shadow-sm ring ring-line", className)} {...attrs}>
  {icon && <span class="mb-2.5 block text-2xl leading-none" aria-hidden="true">{icon}</span>}
  <h3 class="m-0 text-sm font-bold leading-snug text-text">{title}</h3>
  <div class="mt-1.5 text-[0.8125rem] leading-normal text-text-subtle">
    <slot />
  </div>
</article>
