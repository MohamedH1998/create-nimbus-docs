---
import { cn } from "@/lib/cn";
import type { HTMLAttributes } from "astro/types";
import type { TocEntry } from "../lib/toc";

interface Props extends HTMLAttributes<"div"> {
  headings: TocEntry[];
}

const { headings, class: className, ...attrs } = Astro.props;
---

{headings.length > 0 && (
  <div class={cn("toc-container", className)} {...attrs}>
    <h2 class="mb-2 text-sm font-semibold text-text">On this page</h2>
    <nav aria-label="Table of contents">
      <ul class="flex list-none flex-col border-l-2 border-line m-0 p-0">
        {headings.map((h) => (
          <li>
            <a
              href={`#${h.slug}`}
              data-toc-link
              data-slug={h.slug}
              class="toc-link block -ml-0.5 border-l-2 border-transparent py-1.5 text-[0.8125rem] leading-snug text-text-subtle no-underline transition-all duration-150"
              style={`padding-left: calc(1.25rem + ${(h.depth - 2)}rem);`}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
)}

<style>
  .toc-link:hover {
    border-left-color: var(--nb-line-strong);
    color: var(--nb-text);
  }
  .toc-link[aria-current="true"] {
    border-left-color: var(--nb-brand);
    color: var(--nb-text);
    font-weight: 500;
  }
</style>

<script>
  function initToc() {
    document.querySelectorAll<HTMLElement>(".toc-container").forEach((container) => {
      if (container.hasAttribute("data-initialized")) return;
      container.setAttribute("data-initialized", "true");

      const links = container.querySelectorAll("[data-toc-link]");
      if (links.length === 0) return;

      const slugs = Array.from(links).map((l) => (l as HTMLElement).dataset.slug!);
      const headings = slugs
        .map((s) => document.getElementById(s))
        .filter(Boolean) as HTMLElement[];

      function setActive(slug: string) {
        links.forEach((l) => l.removeAttribute("aria-current"));
        const active = container.querySelector(`[data-toc-link][data-slug="${slug}"]`);
        active?.setAttribute("aria-current", "true");
      }

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              setActive(entry.target.id);
            }
          }
        },
        { rootMargin: "-80px 0px -60% 0px", threshold: 0 },
      );

      headings.forEach((h) => observer.observe(h));
    });
  }
  initToc();
  document.addEventListener("astro:page-load", initToc);
</script>
