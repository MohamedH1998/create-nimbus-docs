---
import { cn } from "@/lib/cn";
import type { HTMLAttributes } from "astro/types";
import type { Breadcrumb } from "../lib/navigation";

interface Props extends HTMLAttributes<"nav"> {
  items: Breadcrumb[];
  /** Max visible crumbs before collapsing middle items (default: 4) */
  maxVisible?: number;
}

const { items, maxVisible = 4, class: className, ...attrs } = Astro.props;

// Determine if we need to collapse the middle
const shouldCollapse = items.length > maxVisible;
// When collapsed: Home + first segment + ... + last 2 (parent + current)
const headCount = 2; // Home + first segment
const tailCount = 2; // parent + current page
const headItems = shouldCollapse ? items.slice(0, headCount) : items;
const collapsedItems = shouldCollapse ? items.slice(headCount, items.length - tailCount) : [];
const tailItems = shouldCollapse ? items.slice(items.length - tailCount) : [];
---

{items.length > 1 && (
  <nav aria-label="Breadcrumb" class={cn("text-xs font-medium", className)} {...attrs}>
    <ol class="flex flex-wrap items-center gap-y-0.5 text-text-subtle">
      {/* Head items (always visible) */}
      {headItems.map((crumb, i) => (
        <li class="flex items-center">
          {i > 0 && <span class="mx-1.5 text-text-subtle/50">/</span>}
          {!shouldCollapse && i === items.length - 1 ? (
            <span class="text-text truncate max-w-[12rem]">{crumb.label}</span>
          ) : (
            <a href={crumb.href} class="hover:text-text transition-colors truncate max-w-[12rem]">
              {crumb.label}
            </a>
          )}
        </li>
      ))}

      {/* Collapsed middle — details/summary popover */}
      {shouldCollapse && collapsedItems.length > 0 && (
        <li class="flex items-center">
          <span class="mx-1.5 text-text-subtle/50">/</span>
          <details class="relative group">
            <summary
              class="list-none cursor-pointer select-none rounded px-1 py-0.5 hover:bg-interact hover:text-text transition-colors"
              aria-label={`Show ${collapsedItems.length} more path segments`}
            >
              <span class="tracking-widest">&hellip;</span>
            </summary>
            <div class="absolute left-0 top-full z-40 mt-1 min-w-[10rem] max-w-[16rem] rounded-lg border border-line bg-base p-1 shadow-lg">
              {collapsedItems.map((crumb) => (
                <a
                  href={crumb.href}
                  class="block truncate rounded-md px-2.5 py-1.5 text-xs text-text-subtle hover:bg-interact hover:text-text transition-colors"
                >
                  {crumb.label}
                </a>
              ))}
            </div>
          </details>
        </li>
      )}

      {/* Tail items (always visible when collapsed) */}
      {shouldCollapse && tailItems.map((crumb, i) => (
        <li class="flex items-center">
          <span class="mx-1.5 text-text-subtle/50">/</span>
          {i === tailItems.length - 1 ? (
            <span class="text-text truncate max-w-[12rem]">{crumb.label}</span>
          ) : (
            <a href={crumb.href} class="hover:text-text transition-colors truncate max-w-[12rem]">
              {crumb.label}
            </a>
          )}
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  /* Remove default marker from <summary> across browsers */
  details summary::-webkit-details-marker { display: none; }

  /* Close the popover when clicking outside */
  details[open] > summary::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: 39;
    cursor: default;
  }
</style>
