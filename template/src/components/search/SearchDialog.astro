---
/**
 * SearchDialog — Cmd+K command palette with Pagefind search.
 * Composes Dialog primitives for modal behavior.
 */
import { Dialog, DialogContent, DialogClose } from "@/components/ui/dialog";
---

<Dialog aria-label="Search documentation" data-search-dialog>
  <DialogContent class="max-w-lg">

    {/* Input bar */}
    <div class="flex items-center gap-3 bg-base px-4 py-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-text-subtle" fill="currentColor" viewBox="0 0 256 256" aria-hidden="true">
        <path d="M232.49,215.51,185,168a92.12,92.12,0,1,0-17,17l47.53,47.54a12,12,0,0,0,17-17ZM44,112a68,68,0,1,1,68,68A68.07,68.07,0,0,1,44,112Z" />
      </svg>
      <input
        data-search-input
        role="combobox"
        aria-expanded="false"
        aria-haspopup="listbox"
        aria-autocomplete="list"
        aria-controls="search-listbox"
        type="text"
        placeholder="Search documentation…"
        class="flex-1 border-none bg-transparent text-sm text-text placeholder:text-text-subtle focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:rounded-sm"
        autocomplete="off"
        spellcheck="false"
        autocorrect="off"
        autocapitalize="none"
      />
      <DialogClose
        class="flex shrink-0 items-center p-0 m-0 bg-inherit border-0 cursor-pointer"
        aria-label="Close search"
      >
        <kbd class="pointer-events-none inline-flex h-5 min-w-5 items-center justify-center rounded-sm px-1 text-xs font-medium select-none bg-tint text-text-subtle border border-line">Esc</kbd>
      </DialogClose>
    </div>

    {/* Results */}
    <div
      data-search-results
      role="listbox"
      id="search-listbox"
      aria-orientation="vertical"
      class="mb-2 min-h-0 flex-1 overflow-y-auto rounded-b-lg bg-base p-2 ring-1 ring-line"
    >
      <p data-search-empty class="py-8 text-center text-sm text-text-subtle">
        Type to search…
      </p>
    </div>

    {/* Footer keyboard hints */}
    <div class="flex items-center gap-4 px-4 py-2.5 text-xs text-text-subtle">
      <span class="flex items-center gap-1">
        <kbd class="pointer-events-none inline-flex h-5 min-w-5 items-center justify-center rounded-sm px-1 text-xs font-medium select-none bg-tint text-text-subtle border border-line">&uarr;</kbd>
        <kbd class="pointer-events-none inline-flex h-5 min-w-5 items-center justify-center rounded-sm px-1 text-xs font-medium select-none bg-tint text-text-subtle border border-line">&darr;</kbd>
        <span>to navigate</span>
      </span>
      <span class="flex items-center gap-1">
        <kbd class="pointer-events-none inline-flex h-5 min-w-5 items-center justify-center rounded-sm px-1 text-xs font-medium select-none bg-tint text-text-subtle border border-line">&crarr;</kbd>
        <span>to select</span>
      </span>
    </div>

  </DialogContent>
</Dialog>

<script>
  import { initSearch } from "@/lib/client/search";

  type SearchDialogElement = HTMLDialogElement & {
    __openSearchDialog?: () => void;
  };

  function getPrimarySearchDialog(): SearchDialogElement | null {
    return document.querySelector<SearchDialogElement>(
      "[data-search-dialog][data-search-initialized]",
    );
  }

  function getSearchDialogByTarget(target: string | null): SearchDialogElement | null {
    if (!target) return null;

    const byId = document.getElementById(target);
    if (byId instanceof HTMLDialogElement && byId.hasAttribute("data-search-dialog")) {
      return byId as SearchDialogElement;
    }

    return Array.from(
      document.querySelectorAll<SearchDialogElement>("[data-search-dialog][data-search-id]"),
    ).find((dialog) => dialog.getAttribute("data-search-id") === target) ?? null;
  }

  function getSearchDialogForTrigger(trigger: Element): SearchDialogElement | null {
    const target =
      trigger.getAttribute("data-search-trigger-for") ??
      trigger.getAttribute("aria-controls");

    return getSearchDialogByTarget(target) ?? getPrimarySearchDialog();
  }

  function bindSearchDialogGlobals(): void {
    if (document.documentElement.hasAttribute("data-search-dialog-globals")) return;
    document.documentElement.setAttribute("data-search-dialog-globals", "true");

    document.addEventListener("click", (event) => {
      const trigger = (event.target as Element | null)?.closest("[data-search-trigger]");
      if (!trigger) return;

      getSearchDialogForTrigger(trigger)?.__openSearchDialog?.();
    });

    document.addEventListener("keydown", (event) => {
      if (!(event.metaKey || event.ctrlKey) || event.key.toLowerCase() !== "k") return;

      const dialog = getPrimarySearchDialog();
      if (!dialog) return;
      event.preventDefault();

      if (dialog.open) {
        dialog.close();
      } else {
        dialog.__openSearchDialog?.();
      }
    });
  }

  function initSearchDialog() {
    document.querySelectorAll<SearchDialogElement>("[data-search-dialog]").forEach((dialog) => {
      if (dialog.hasAttribute("data-search-initialized")) return;
      dialog.setAttribute("data-search-initialized", "true");

      const input = dialog.querySelector<HTMLInputElement>("[data-search-input]");
      const resultsContainer = dialog.querySelector<HTMLElement>("[data-search-results]");
      const emptyState = dialog.querySelector<HTMLElement>("[data-search-empty]");

      if (!input || !resultsContainer || !emptyState) return;

      const search = initSearch({
        input,
        resultsContainer,
        emptyState,
        onNavigate: () => dialog.close(),
      });

      function openDialog() {
        if (!dialog.open) dialog.showModal();
        void search.reset();
      }

      dialog.__openSearchDialog = openDialog;
    });

    bindSearchDialogGlobals();
  }

  initSearchDialog();
  document.addEventListener("astro:page-load", initSearchDialog);
</script>
