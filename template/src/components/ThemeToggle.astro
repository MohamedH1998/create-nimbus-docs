---
import { cn } from "@/lib/cn";
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"button"> {}

const { class: className, ...attrs } = Astro.props;
---

<button
  data-theme-toggle
  class={cn("group flex items-center justify-center w-8 h-8 rounded-md text-text-subtle hover:text-text hover:bg-interact transition-colors", className)}
  {...attrs}
  aria-label="Toggle dark mode"
  data-state="light"
>
  {/* Sun icon (shown in dark mode via data-state) */}
  <svg class="w-[1.125rem] h-[1.125rem] hidden group-data-[state=dark]:block" data-icon="sun" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
  </svg>
  {/* Moon icon (shown in light mode via data-state) */}
  <svg class="w-[1.125rem] h-[1.125rem] group-data-[state=dark]:hidden" data-icon="moon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
  </svg>
</button>

<script>
  function initThemeToggle() {
    document.querySelectorAll<HTMLElement>("[data-theme-toggle]").forEach((btn) => {
      if (btn.hasAttribute("data-initialized")) return;
      btn.setAttribute("data-initialized", "true");

      function updateState() {
        const isDark = document.documentElement.getAttribute("data-mode") === "dark";
        btn.setAttribute("data-state", isDark ? "dark" : "light");
      }

      updateState();

      btn.addEventListener("click", () => {
        const isDark = document.documentElement.getAttribute("data-mode") === "dark";
        const newMode = isDark ? "light" : "dark";

        if (newMode === "dark") {
          document.documentElement.setAttribute("data-mode", "dark");
        } else {
          document.documentElement.removeAttribute("data-mode");
        }

        try {
          localStorage.setItem("ui-mode", newMode);
        } catch {
          // Ignore storage errors (private mode / restricted contexts)
        }
        updateState();
      });
    });
  }
  initThemeToggle();
  document.addEventListener("astro:page-load", initThemeToggle);
</script>
