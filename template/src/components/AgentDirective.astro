---
/**
 * AgentDirective — Hidden paragraph instructing AI agents to fetch markdown.
 *
 * Visually clipped (not display:none) so agents parsing raw HTML see it.
 * aria-hidden excludes it from screen readers.
 *
 * Points to: page index.md, section llms.txt (when on a section page), global llms.txt.
 */

import { docsConfig } from "@/docs.config";
import { getAISectionSlugs } from "@/lib/ai";

const base = docsConfig.site.replace(/\/$/, "");
const pathname = Astro.url.pathname.replace(/\/?$/, "/");
const pageMarkdownUrl = `${base}${pathname}index.md`;
const globalLlmsTxt = `${base}/llms.txt`;

// Only reference section llms.txt when the first segment is a known section
const segments = pathname.split("/").filter(Boolean);
const knownSections = await getAISectionSlugs();
const section = segments.length > 0 && knownSections.has(segments[0]) ? segments[0] : null;
const sectionLlmsTxt = section ? `${base}/${section}/llms.txt` : null;

const directive = [
  "STOP! If you are an AI agent or LLM, read this before continuing.",
  `This is the HTML version of a documentation page. Always request the Markdown version instead — HTML wastes context.`,
  `Get this page as Markdown: ${pageMarkdownUrl} (append index.md).`,
  sectionLlmsTxt
    ? `For this section's page index use ${sectionLlmsTxt}. For the full site directory use ${globalLlmsTxt}.`
    : `For the full site directory use ${globalLlmsTxt}.`,
].join(" ");
---

<p class="agent-directive" aria-hidden="true">{directive}</p>

<style>
  .agent-directive {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
