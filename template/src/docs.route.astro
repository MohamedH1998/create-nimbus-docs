---
/**
 * docs.route.astro — Route composition for Nimbus
 *
 * This is the rendering entrypoint for documentation pages.
 * It receives a content entry and composes the full page layout.
 * Edit this to change how pages are assembled (layout, sidebar, TOC).
 *
 * Wired into Astro via the thin shim at pages/[...slug].astro.
 */
import "./styles/globals.css";
import "./styles/prose.css";
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import DocsLayout from "@/layouts/DocsLayout.astro";
import { buildSidebarTree } from "@/lib/sidebar";
import { getBreadcrumbs, getPrevNext } from "@/lib/navigation";
import { getHeadings } from "@/lib/toc";
import { getVisibleDocs } from "@/lib/content";
import { docsConfig } from "./docs.config";
import Hero from "@/components/Hero.astro";

interface Props {
  entry: CollectionEntry<"docs">;
}

const { entry } = Astro.props;
type DocsEntryWithFilePath = CollectionEntry<"docs"> & { filePath?: string };
const { Content, headings: rawHeadings } = await render(entry);

const docs = await getVisibleDocs();
const slug = entry.id === "index" ? "" : entry.id;
const currentPath = slug ? `/${slug}` : "/";
const validInternalLinks = new Set(
  docs.map((doc) => (doc.id === "index" ? "/" : `/${doc.id}`)),
);
const sidebar = buildSidebarTree(docs, currentPath, docsConfig.sidebar);
const breadcrumbs = getBreadcrumbs(slug, docsConfig.homeLabel);
const headings = getHeadings(rawHeadings, entry.data.tableOfContents);
const prevNext = getPrevNext(
  currentPath,
  sidebar,
  { prev: entry.data.prev, next: entry.data.next },
  validInternalLinks,
);
const template = entry.data.template ?? "doc";
const hasBodyContent = typeof entry.body === "string" && entry.body.trim().length > 0;

// Derive edit URL. filePath is set by Astro's glob loader (includes extension).
const entryFilePath = (entry as DocsEntryWithFilePath).filePath;
const contentPath = entryFilePath ?? `src/content/docs/${entry.id}.mdx`;
const editUrl = docsConfig.editPattern
  ? docsConfig.editPattern.replace("{path}", contentPath)
  : docsConfig.editPattern !== null && docsConfig.github
    ? `${docsConfig.github.replace(/\/$/, "")}/edit/main/${contentPath}`
    : undefined;
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  sidebar={sidebar}
  headings={headings}
  breadcrumbs={breadcrumbs}
  prevNext={prevNext}
  template={template}
  banner={entry.data.banner}
  head={entry.data.head}
  pagefind={entry.data.pagefind}
  lastUpdated={entry.data.lastUpdated}
  editUrl={editUrl}
  draft={entry.data.draft}
  noindex={entry.data.noindex}
  aiDeprioritize={entry.data.aiDeprioritize}
>
  {template === "splash" ? (
    <Fragment>
      {entry.data.hero && (
        <Hero
          title={entry.data.hero.title ?? entry.data.title}
          tagline={entry.data.hero.tagline}
          actions={entry.data.hero.actions}
        />
      )}

      {hasBodyContent && (
        <section class="px-6 pb-16 sm:pb-20">
          <div class="mx-auto w-full max-w-(--nb-content-max)">
            <article class="docs-content max-w-none">
              <Content />
            </article>
          </div>
        </section>
      )}
    </Fragment>
  ) : (
    <Content />
  )}
</DocsLayout>
