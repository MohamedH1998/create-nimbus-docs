{
  "name": "nimbus-starter",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "tsc --noEmit",
    "check:astro": "astro check",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,astro,css,md,mdx,json}\"",
    "ci": "tsc --noEmit && astro check && eslint . && astro build"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "astro": "^6.1.6",
    "astro-expressive-code": "^0.41.7",
    "clsx": "^2.1.1",
    "rehype-slug": "^6.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.1.4",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.5.0",
    "pagefind": "^1.3.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.1"
  }
}
